<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bankingsystem.controller.AdminController">
    <top>
        <HBox spacing="10" style="-fx-background-color: #1f2937;" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="12" bottom="10" left="12"/>
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="Admin Dashboard"/>
            <Button onAction="#logout" text="Logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <TableView fx:id="customersTable" prefHeight="280">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="70" text="ID"/>
                    <TableColumn fx:id="nameColumn" prefWidth="180" text="Full Name"/>
                    <TableColumn fx:id="usernameColumn" prefWidth="130" text="Username"/>
                    <TableColumn fx:id="accountColumn" prefWidth="160" text="Account No."/>
                    <TableColumn fx:id="balanceColumn" prefWidth="130" text="Balance"/>
                    <TableColumn fx:id="activeColumn" prefWidth="100" text="Active"/>
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button onAction="#activateCustomer" text="Activate"/>
                <Button onAction="#blockCustomer" text="Block"/>
                <Button onAction="#viewTransactions" text="View Transactions"/>
            </HBox>

            <VBox spacing="8">
                <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Create Customer"/>
                <HBox spacing="8">
                    <TextField fx:id="fullNameField" promptText="Full_Name"/>
                    <TextField fx:id="newUsernameField" promptText="Username"/>
                    <TextField fx:id="newPasswordField" promptText="Password"/>
                    <TextField fx:id="openingBalanceField" promptText="Opening Balance"/>
                    <Button onAction="#createCustomer" text="Create"/>
                </HBox>
            </VBox>

            <TextArea fx:id="transactionsArea" prefHeight="170" promptText="Selected customer's transactions appear here"/>
            <Label fx:id="statusLabel" style="-fx-text-fill: #0f5132;"/>
        </VBox>
    </center>
</BorderPane>