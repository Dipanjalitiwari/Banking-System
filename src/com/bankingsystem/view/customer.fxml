<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bankingsystem.controller.CustomerController">
    <top>
        <HBox spacing="12" style="-fx-background-color: #0c4a6e;" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="12" bottom="10" left="12"/>
            </padding>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
            <Label fx:id="logoutTimerLabel" style="-fx-text-fill: #fde68a; -fx-font-size: 13; -fx-font-weight: bold;" text="Auto logout in: 05:00"/>
            <Button onAction="#logout" text="Logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label fx:id="accountNumberLabel" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <Label fx:id="balanceLabel" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <HBox spacing="20">
                <Label fx:id="totalDepositsLabel" style="-fx-font-size: 13; -fx-text-fill: #14532d; -fx-font-weight: bold;" text="Total Deposits: 0.00"/>
                <Label fx:id="totalWithdrawalsLabel" style="-fx-font-size: 13; -fx-text-fill: #991b1b; -fx-font-weight: bold;" text="Total Withdrawals: 0.00"/>
            </HBox>

            <HBox spacing="8">
                <TextField fx:id="depositField" promptText="Deposit Amount"/>
                <Button onAction="#deposit" text="Deposit"/>
            </HBox>

            <HBox spacing="8">
                <TextField fx:id="withdrawField" promptText="Withdraw Amount"/>
                <Button onAction="#withdraw" text="Withdraw"/>
            </HBox>

            <HBox spacing="8">
                <TextField fx:id="transferAccountField" promptText="Destination Account Number"/>
                <TextField fx:id="transferAmountField" promptText="Transfer Amount"/>
                <Button onAction="#transfer" text="Transfer"/>
            </HBox>

            <TextArea fx:id="historyArea" prefHeight="280" promptText="Transaction history"/>
            <Label fx:id="statusLabel" style="-fx-text-fill: #0f5132;"/>
        </VBox>
    </center>
</BorderPane>